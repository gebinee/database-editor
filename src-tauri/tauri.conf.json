{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gebinee-database-editor",
  "version": "0.0.0",
  "identifier": "com.gebinee.database-editor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Gebinee Database Editor",
        "width": 1280,
        "height": 800,
        "minWidth": 1240,
        "minHeight": 775
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "deb",
      "rpm",
      "appimage",
      "dmg",
      "app"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "license": "MIT",
    "licenseFile": "../LICENSE",
    "windows": {
      "nsis": {
        "installMode": "both",
        "installerIcon": "icons/icon.ico",
        "installerHooks": "scripts/nsis-hooks.nsh"
      }
    },
    "linux": {
      "deb": {
        "preRemoveScript": "scripts/linux-prerm.sh",
        "postRemoveScript": "scripts/linux-postrm.sh"
      },
      "rpm": {
        "preRemoveScript": "scripts/linux-prerm.sh",
        "postRemoveScript": "scripts/linux-postrm.sh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE0NkM1QjM2QzZCNjA5ODYKUldTR0NiYkdObHRzcElmUXprL2FjLzFqdkdmQ2MzRGtDdmxpbm9vT2NZUTEzaWduVnRYejF1MzAK",
      "endpoints": [
        "https://github.com/gebinee/update-info/releases/download/database-editor/latest.json",
        "https://gh-proxy.org/https://github.com/gebinee/update-info/releases/download/database-editor/latest-proxy.json"
      ]
    },
    "process": {}
  }
}
